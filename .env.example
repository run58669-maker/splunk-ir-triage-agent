# Vertex AI (preferred — uses Gemini via GCP)
GCP_PROJECT=your-gcp-project-id
GCP_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash
# gcloud auth application-default login

# Or, Google AI Studio fallback (free tier — quota limited)
# GEMINI_API_KEY=AIza...

# Splunk MCP Server (filled after Splunkbase app 7931 setup)
SPLUNK_MCP_URL=https://localhost:8089/services/mcp
SPLUNK_MCP_TOKEN=

# TLS — set to 0 for self-signed local Splunk; 1 for prod
TLS_VERIFY=0
